<label for="passwordInput" class="text-sm text-neutral opacity-60">Password</label>
<div class="relative">
  <input type="password" id="passwordInput" name="password" class="input w-full" required />
  <button class="pw-visibility-btn btn btn-circle btn-sm btn-ghost absolute top-1 right-1" type="button">
    <img src="/icons/eyes/eye-off.svg" class="opacity-60 w-5 h-5" />
  </button>
</div>

<script src="/js/passwordScript.js" defer></script>